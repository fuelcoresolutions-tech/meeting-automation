{
  "name": "fuelcore",
  "version": "1.0.0",
  "description": "Notion API integration for projects and tasks with Claude Agent",
  "main": "index.js",
  "type": "module",
  "scripts": {
    "start": "node index.js",
    "webhook": "node webhook-server.js",
    "agent": "cd agent && python -m uvicorn main:app --host 0.0.0.0 --port 8000",
    "agent:install": "cd agent && pip install -r requirements.txt",
    "dev": "concurrently \"npm run webhook\" \"npm run agent\"",
    "pull": "node pull-transcripts.js",
    "build-batch": "node build-batch.js",
    "submit-batch": "node submit-batch.js",
    "fetch-results": "node fetch-results.js",
    "batch-status": "node submit-batch.js --status",
    "batch-poll": "node submit-batch.js --poll",
    "pipeline": "node pull-transcripts.js && node build-batch.js && node submit-batch.js"
  },
  "dependencies": {
    "@notionhq/client": "^2.2.14",
    "axios": "^1.6.0",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "concurrently": "^8.2.0"
  },
  "devDependencies": {
  }
}
